<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
    UI-тесты (Appium).
    Запуск: ./gradlew uiTest
    С облаком: ./gradlew uiTest -Dtest.mode=cloud

    parallel="tests" — каждый <test> блок в своём потоке.
    НЕ parallel="methods" — потому что AndroidDriver не потокобезопасен.
    Один драйвер = одно устройство = один поток.
-->
<suite name="UiSuite" parallel="tests" thread-count="2" verbose="2">

    <test name="Checkbox Tests">
        <classes>
            <class name="org.ugina.tests.MainPageTest"/>
        </classes>
    </test>

</suite>