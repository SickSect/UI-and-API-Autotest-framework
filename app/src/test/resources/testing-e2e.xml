<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
    DB + E2E тесты.
    Запуск: ./gradlew e2eTest

    parallel="false" — тесты зависят друг от друга,
    каждый шаг использует состояние, созданное предыдущим.
-->
<suite name="E2E Suite" verbose="2">

    <test name="Database Tests" parallel="false">
        <classes>
            <class name="org.ugina.apiTests.DbClientTest"/>
        </classes>
    </test>

    <test name="End-to-End Test" parallel="false">
        <classes>
            <class name="org.ugina.apiTests.SimpleEndToEndTest"/>
        </classes>
    </test>

</suite>