<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
    SSL/сертификатные тесты.
    Запуск: ./gradlew sslTest
-->
<suite name="SslSuite" parallel="methods" thread-count="2" verbose="2">
    <listeners>
        <listener class-name="org.ugina.retry.RetryListener"/>
    </listeners>
    <test name="SSL Tests">
        <classes>
            <class name="org.ugina.apiTests.SimpleSslConfigTest"/>
        </classes>
    </test>

</suite>